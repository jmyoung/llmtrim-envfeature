{
  "productName": "llmtrim",
  "identifier": "io.github.fkiene.llmtrim-tray",
  "build": {
    "frontendDist": "./ui"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'none'; font-src 'self' data:; object-src 'none'; frame-src 'none'"
    },
    "windows": [
      {
        "label": "popover",
        "title": "llmtrim",
        "width": 360,
        "height": 480,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "resources": [],
    "copyright": "",
    "category": "Utility",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": []
    }
  }
}
